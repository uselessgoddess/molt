+        assert_eq!(byte, [199]);
+    }
+
+    #[test]
+    fn later_writes_overlay_base_data_and_can_extend_sparsely() {
+        let mut bytes = image();
+        let mut block = [0; BLOCK];
+        let mut journal =
+            Journal::mount(Loopback::writable(&mut bytes).expect("image"), &mut block)
+                .expect("mount");
