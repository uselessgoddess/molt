+        let mut contents = [0xa5; 20];
+        let read = journal.read(base, 0, &mut contents).expect("overlay read");
+
+        assert_eq!(read, 16);
+        assert_eq!(&contents[..16], b"imWRITEle\0\0\0tail");
+    }
